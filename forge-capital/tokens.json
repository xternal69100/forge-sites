{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "clair-capital-v2 — système Seline Analytics / Refero pour un cockpit financier humain.",
  "color": {
    "$type": "color",
    "paper": {"$value": {"colorSpace": "srgb", "components": [0.969, 0.965, 0.949], "hex": "#F7F6F2"}},
    "surface": {"$value": {"colorSpace": "srgb", "components": [1, 1, 1], "hex": "#FFFFFF"}},
    "ink": {"$value": {"colorSpace": "srgb", "components": [0.125, 0.129, 0.141], "hex": "#202124"}},
    "muted": {"$value": {"colorSpace": "srgb", "components": [0.431, 0.439, 0.435], "hex": "#6E706F"}},
    "line": {"$value": {"colorSpace": "srgb", "components": [0.871, 0.867, 0.843], "hex": "#DEDDD7"}},
    "cyan": {"$value": {"colorSpace": "srgb", "components": [0, 0.663, 0.78], "hex": "#00A9C7"}},
    "cyanSoft": {"$value": {"colorSpace": "srgb", "components": [0.875, 0.969, 0.984], "hex": "#DFF7FB"}},
    "danger": {"$value": {"colorSpace": "srgb", "components": [0.718, 0.227, 0.227], "hex": "#B73A3A"}},
    "warning": {"$value": {"colorSpace": "srgb", "components": [0.608, 0.404, 0.075], "hex": "#9B6713"}},
    "success": {"$value": {"colorSpace": "srgb", "components": [0.141, 0.439, 0.29], "hex": "#24704A"}}
  },
  "spacing": {"$type": "dimension", "xs": {"$value": {"value": 4, "unit": "px"}}, "sm": {"$value": {"value": 8, "unit": "px"}}, "md": {"$value": {"value": 12, "unit": "px"}}, "lg": {"$value": {"value": 18, "unit": "px"}}, "xl": {"$value": {"value": 30, "unit": "px"}}},
  "radius": {"$type": "dimension", "small": {"$value": {"value": 7, "unit": "px"}}, "card": {"$value": {"value": 12, "unit": "px"}}}
}
