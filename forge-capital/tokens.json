{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Cockpit de preuve noir et vert, dense mais lisible, inspiré des terminaux Matrix sans théâtraliser l’activité.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.424,
          1,
          0.561
        ],
        "hex": "#6cff8f"
      }
    },
    "primaryStrong": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.196,
          0.91,
          0.459
        ],
        "hex": "#32e875"
      }
    },
    "primaryDim": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.09,
          0.239,
          0.153
        ],
        "hex": "#173d27"
      }
    },
    "background": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.02,
          0.031,
          0.024
        ],
        "hex": "#050806"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.039,
          0.063,
          0.047
        ],
        "hex": "#0a100c"
      }
    },
    "surfaceRaised": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.063,
          0.102,
          0.075
        ],
        "hex": "#101a13"
      }
    },
    "surfaceGlass": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.051,
          0.09,
          0.067
        ],
        "hex": "#0d1711"
      }
    },
    "border": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.157,
          0.294,
          0.2
        ],
        "hex": "#284b33"
      }
    },
    "text": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.945,
          1,
          0.957
        ],
        "hex": "#f1fff4"
      }
    },
    "textMuted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.655,
          0.788,
          0.686
        ],
        "hex": "#a7c9af"
      }
    },
    "info": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.459,
          0.843,
          1
        ],
        "hex": "#75d7ff"
      }
    },
    "warning": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.82,
          0.4
        ],
        "hex": "#ffd166"
      }
    },
    "danger": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.482,
          0.537
        ],
        "hex": "#ff7b89"
      }
    },
    "paper": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.773,
          0.639,
          1
        ],
        "hex": "#c5a3ff"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 40,
        "unit": "px"
      }
    },
    "xxl": {
      "$value": {
        "value": 72,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 6,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 12,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 20,
        "unit": "px"
      }
    },
    "pill": {
      "$value": {
        "value": 999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "display": {
      "$type": "typography",
      "$value": {
        "fontFamily": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
        "fontSize": {
          "value": 4,
          "unit": "rem"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": -0.05,
          "unit": "em"
        }
      }
    },
    "h1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
        "fontSize": {
          "value": 3,
          "unit": "rem"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": -0.04,
          "unit": "em"
        }
      }
    },
    "h2": {
      "$type": "typography",
      "$value": {
        "fontFamily": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
        "fontSize": {
          "value": 2,
          "unit": "rem"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": -0.03,
          "unit": "em"
        }
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter, ui-sans-serif, system-ui, sans-serif",
        "fontSize": {
          "value": 1,
          "unit": "rem"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": 0,
          "unit": "em"
        }
      }
    },
    "label": {
      "$type": "typography",
      "$value": {
        "fontFamily": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
        "fontSize": {
          "value": 0.75,
          "unit": "rem"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": 0.08,
          "unit": "em"
        }
      }
    }
  }
}
