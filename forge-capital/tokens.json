{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "matrix-learning-v1 — cockpit pétrole/cyan/vert dense Monitor / Operate, replay borné d’artefacts PAPER et observation Hyperliquid read-only.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.008,
          0.031,
          0.051
        ],
        "hex": "#02080d"
      }
    },
    "panel": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.027,
          0.075,
          0.106
        ],
        "hex": "#07131b"
      }
    },
    "panelStrong": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.043,
          0.11,
          0.149
        ],
        "hex": "#0b1c26"
      }
    },
    "line": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.09,
          0.216,
          0.275
        ],
        "hex": "#173746"
      }
    },
    "matrix": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.396,
          1,
          0.604
        ],
        "hex": "#65ff9a"
      }
    },
    "cyan": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.208,
          0.906,
          1
        ],
        "hex": "#35e7ff"
      }
    },
    "cyanSoft": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.6,
          0.957,
          1
        ],
        "hex": "#99f4ff"
      }
    },
    "text": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.851,
          0.953,
          0.969
        ],
        "hex": "#d9f3f7"
      }
    },
    "muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.467,
          0.6,
          0.643
        ],
        "hex": "#7799a4"
      }
    },
    "warning": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.608,
          0.259
        ],
        "hex": "#ff9b42"
      }
    },
    "danger": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.365,
          0.384
        ],
        "hex": "#ff5d62"
      }
    },
    "success": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.263,
          0.941,
          0.631
        ],
        "hex": "#43f0a1"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 12,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 20,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 32,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 2,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 6,
        "unit": "px"
      }
    }
  },
  "typography": {
    "display": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Arial Narrow, Impact, Arial, sans-serif",
        "fontSize": {
          "value": 5,
          "unit": "rem"
        },
        "fontWeight": 900,
        "letterSpacing": {
          "value": 0.025,
          "unit": "em"
        }
      }
    },
    "h1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Arial Narrow, Impact, Arial, sans-serif",
        "fontSize": {
          "value": 3,
          "unit": "rem"
        },
        "fontWeight": 900,
        "letterSpacing": {
          "value": 0.025,
          "unit": "em"
        }
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Arial, Helvetica, sans-serif",
        "fontSize": {
          "value": 0.9375,
          "unit": "rem"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": 0,
          "unit": "em"
        }
      }
    },
    "data": {
      "$type": "typography",
      "$value": {
        "fontFamily": "ui-monospace, SFMono-Regular, Menlo, Consolas, monospace",
        "fontSize": {
          "value": 0.75,
          "unit": "rem"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": 0.04,
          "unit": "em"
        }
      }
    }
  }
}
