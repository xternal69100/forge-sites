{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Une identité premium, claire et rassurante pour une offre d'assistant administratif agentique destinée aux artisans et petites structures suisses.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.118,
          0.227,
          0.373
        ],
        "hex": "#1e3a5f"
      }
    },
    "primarySoft": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.847,
          0.894,
          0.941
        ],
        "hex": "#d8e4f0"
      }
    },
    "secondary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.4,
          0.439,
          0.522
        ],
        "hex": "#667085"
      }
    },
    "tertiary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.549,
          0.31,
          0.133
        ],
        "hex": "#8c4f22"
      }
    },
    "neutral": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.965,
          0.953,
          0.933
        ],
        "hex": "#f6f3ee"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    },
    "ink": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.059,
          0.09,
          0.165
        ],
        "hex": "#0f172a"
      }
    },
    "muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.91,
          0.882,
          0.843
        ],
        "hex": "#e8e1d7"
      }
    },
    "success": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.133,
          0.329,
          0.239
        ],
        "hex": "#22543d"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 12,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 20,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 32,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 56,
        "unit": "px"
      }
    },
    "2xl": {
      "$value": {
        "value": 80,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 12,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 18,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 30,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 40,
        "unit": "px"
      }
    }
  },
  "typography": {
    "h1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Manrope",
        "fontSize": {
          "value": 3.75,
          "unit": "rem"
        },
        "fontWeight": 800,
        "letterSpacing": {
          "value": -0.035,
          "unit": "em"
        }
      }
    },
    "h2": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Manrope",
        "fontSize": {
          "value": 2.4,
          "unit": "rem"
        },
        "fontWeight": 800,
        "letterSpacing": {
          "value": -0.025,
          "unit": "em"
        }
      }
    },
    "h3": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Manrope",
        "fontSize": {
          "value": 1.5,
          "unit": "rem"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": -0.02,
          "unit": "em"
        }
      }
    },
    "body-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1.125,
          "unit": "rem"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": 0,
          "unit": "em"
        }
      }
    },
    "body-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1,
          "unit": "rem"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": 0,
          "unit": "em"
        }
      }
    },
    "label": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 0.78,
          "unit": "rem"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": 0.08,
          "unit": "em"
        }
      }
    }
  }
}
