{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Un index typographique public, précis et tactile, construit comme un établi éditorial contemporain.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.769,
          0.263,
          0.173
        ],
        "hex": "#c4432c"
      }
    },
    "ink": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.082,
          0.082,
          0.071
        ],
        "hex": "#151512"
      }
    },
    "paper": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.949,
          0.937,
          0.898
        ],
        "hex": "#f2efe5"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.988,
          0.961
        ],
        "hex": "#fffcf5"
      }
    },
    "muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.361,
          0.357,
          0.329
        ],
        "hex": "#5c5b54"
      }
    },
    "line": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.78,
          0.757,
          0.702
        ],
        "hex": "#c7c1b3"
      }
    },
    "ember": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.769,
          0.263,
          0.173
        ],
        "hex": "#c4432c"
      }
    },
    "emberDark": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.467,
          0.149,
          0.09
        ],
        "hex": "#772617"
      }
    },
    "acid": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.851,
          0.89,
          0.365
        ],
        "hex": "#d9e35d"
      }
    },
    "success": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.114,
          0.392,
          0.251
        ],
        "hex": "#1d6440"
      }
    },
    "danger": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.557,
          0.18,
          0.141
        ],
        "hex": "#8e2e24"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 40,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 2,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 6,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 14,
        "unit": "px"
      }
    }
  },
  "typography": {
    "elanovre": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Elanovre, Arial, sans-serif",
        "fontSize": {
          "value": 4,
          "unit": "rem"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": -0.02,
          "unit": "em"
        }
      }
    },
    "keravolt": {
      "$type": "typography",
      "$value": {
        "fontFamily": "KeraVolt Optical, Impact, sans-serif",
        "fontSize": {
          "value": 4,
          "unit": "rem"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": -0.015,
          "unit": "em"
        }
      }
    },
    "h1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Georgia, serif",
        "fontSize": {
          "value": 3,
          "unit": "rem"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": -0.025,
          "unit": "em"
        }
      }
    },
    "h2": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Georgia, serif",
        "fontSize": {
          "value": 1.5,
          "unit": "rem"
        },
        "fontWeight": 600
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Arial, sans-serif",
        "fontSize": {
          "value": 1,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "label": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Arial, sans-serif",
        "fontSize": {
          "value": 0.75,
          "unit": "rem"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": 0.08,
          "unit": "em"
        }
      }
    }
  }
}
